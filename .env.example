# Telegram bot tokeni. BotFather'dan olinadi.
BOT_TOKEN=

# PostgreSQL ulanish manzili.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/instagram_downloader?sslmode=disable

# Redis ulanish manzili. Queue, lock va rate limit uchun kerak.
REDIS_URL=redis://localhost:6379

# Superadmin Telegram ID. Bot birinchi startda shu userni SUPERADMIN qiladi.
SUPERADMIN_TELEGRAM_ID=

# App porti.
APP_PORT=8000

# Muhit: development yoki production.
NODE_ENV=development

# Faqat Instagram ishlashi uchun.
ONLY_INSTAGRAM=true

# Boshlang'ich video hajm limiti MBda. Keyin admin botdan o'zgartiradi.
MAX_VIDEO_FILE_SIZE_MB=500

# Boshlang'ich audio hajm limiti MBda. Keyin admin botdan o'zgartiradi.
MAX_AUDIO_FILE_SIZE_MB=100

# Telegram upload limiti MBda.
TELEGRAM_MAX_UPLOAD_MB=2000

# Media vaqtinchalik saqlanadigan asosiy papka.
UPLOADS_DIR=uploads

# Download temp papkasi.
TEMP_DOWNLOAD_DIR=uploads/temp/downloads

# Cache papkasi.
CACHE_DIR=uploads/cache

# Eski temp fayllar necha minutdan keyin o'chiriladi.
TEMP_FILES_TTL_MINUTES=30

# Cleanup service necha minutda bir ishlaydi.
CLEANUP_INTERVAL_MINUTES=10

# yt-dlp executable nomi yoki path.
YTDLP_BIN=yt-dlp

# ffmpeg executable nomi yoki path.
FFMPEG_BIN=ffmpeg

# ffprobe executable nomi yoki path.
FFPROBE_BIN=ffprobe

# Instagram cookies ishlatish. Public link yetmasa cookies bilan urinadi.
INSTAGRAM_USE_COOKIES=true

# Instagram cookies.txt fayl yo'li.
INSTAGRAM_COOKIES_FILE=storage/cookies/instagram.cookies.txt

# Instagram Auto format. Eng tez va mos format.
INSTAGRAM_FORMAT_AUTO=best[ext=mp4]/best

# Instagram original/eng yaxshi sifat.
INSTAGRAM_FORMAT_ORIGINAL=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best

# Instagram 1080p yoki eng yaqin past sifat.
INSTAGRAM_FORMAT_1080=bestvideo[height<=1080][ext=mp4]+bestaudio[ext=m4a]/best[height<=1080][ext=mp4]/best

# Instagram 720p yoki eng yaqin past sifat.
INSTAGRAM_FORMAT_720=bestvideo[height<=720][ext=mp4]+bestaudio[ext=m4a]/best[height<=720][ext=mp4]/best

# Instagram 480p yoki eng yaqin past sifat.
INSTAGRAM_FORMAT_480=bestvideo[height<=480][ext=mp4]+bestaudio[ext=m4a]/best[height<=480][ext=mp4]/best

# Eng kichik hajm uchun.
INSTAGRAM_FORMAT_SMALL=worst[ext=mp4]/worst

# Queue prefix.
QUEUE_PREFIX=instagram_bot

# Instagram download workerlar soni.
INSTAGRAM_DOWNLOAD_QUEUE_CONCURRENCY=5

# Telegram send workerlar soni.
INSTAGRAM_SEND_QUEUE_CONCURRENCY=20

# Audio convert workerlar soni.
AUDIO_QUEUE_CONCURRENCY=2

# Job necha marta qayta urinsin.
QUEUE_JOB_ATTEMPTS=2

# Retry orasidagi kutish vaqti.
QUEUE_BACKOFF_MS=5000

# Bir xil URL + quality lock vaqti.
IN_FLIGHT_LOCK_TTL_SECONDS=180

# Rate limit vaqti sekundda.
RATE_LIMIT_TTL=60

# Rate limit ichida maksimal so'rov.
RATE_LIMIT_LIMIT=30

# Bir user kuniga nechta media yuklashi mumkin.
DAILY_USER_DOWNLOAD_LIMIT=100

# Bot boshlang'ich holati. Keyin admin botdan o'zgartiradi.
BOT_ONLINE=true

# Maintenance boshlang'ich holati. Keyin admin botdan o'zgartiradi.
MAINTENANCE_MODE=false

# Donat karta raqami.
DONATE_CARD_NUMBER=8600000000000000

# Donat karta egasi.
DONATE_CARD_OWNER=YOUR NAME

# Donat matni.
DONATE_TEXT=Donat uchun karta raqami:
